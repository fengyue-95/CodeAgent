      "Bash(find . -name \"*.py\" -type f -exec grep -l \"串行\\\\|并行\\\\|parallel\\\\|serial\" {} \\\\;)",
      "Bash(npm list:*)",
      "Bash(npm view:*)",
      "Bash(code-agent run:*)",
      "Bash(code-agent --help)",
      "Bash(code-agent --verbose run \"test task\")",
      "Bash(code-agent --log-file /tmp/code-agent.log run \"test\")",
